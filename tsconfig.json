{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "noEmit": true,
    "types": ["./worker-configuration.d.ts", "vitest/globals"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "tests/**/*", "worker-configuration.d.ts"]
}
